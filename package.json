{
  "name": "latchly",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p ${PORT:-3000}",
    "leads:apollo": "node scripts/apollo-scrape.js",
    "leads:qualify": "node scripts/qualify-via-cdp.js",
    "leads:qualify:cdp": "node scripts/qualify-via-cdp.js",
    "leads:clean-batch": "node scripts/build-clean-batch.js 25",
    "leads:pipeline": "node scripts/run-leads-pipeline.js 25",
    "leads:pipeline:local": "SKIP_APOLLO_SCRAPE=1 node scripts/run-leads-pipeline.js 25",
    "leads:source": "node scripts/source-leads.js",
    "leads:scrape": "node scripts/auto-scrape.js",
    "leads:daily": "node scripts/daily-pipeline.js",
    "leads:daily:local": "SKIP_SCRAPE=1 node scripts/daily-pipeline.js",
    "leads:daily:dry": "SKIP_SCRAPE=1 SKIP_EMAIL=1 node scripts/daily-pipeline.js",
    "leads:daily:apollo": "APOLLO_MODE=cdp node scripts/daily-pipeline.js",
    "leads:inventory:replenish": "node scripts/replenish-inventory.js",
    "leads:funnel:daily": "SKIP_EMAIL=1 node scripts/latchly-leads/pipeline.js",
    "leads:funnel:daily:email": "node scripts/latchly-leads/pipeline.js",
    "leads:funnel:daily:verbose": "LATCHLY_VERBOSE=1 SKIP_EMAIL=1 node scripts/latchly-leads/pipeline.js",
    "leads:funnel:dry": "DRY_RUN=true LATCHLY_SKIP_LIVE_DISCOVERY=1 LATCHLY_SKIP_BROWSER_AUDIT=1 LATCHLY_SKIP_WEBSITE_FETCH=1 LATCHLY_LEADS_SKIP_DB=1 node scripts/latchly-leads/pipeline.js",
    "leads:funnel:smoke": "LATCHLY_DAILY_TARGET=10 LATCHLY_DAILY_MINIMUM=10 LATCHLY_MAX_AUDIT_ATTEMPTS=40 LATCHLY_MAX_RUN_MINUTES=10 LATCHLY_DIAGNOSTICS=1 SKIP_EMAIL=1 node scripts/latchly-leads/pipeline.js",
    "leads:funnel:archive-bad-import": "node scripts/latchly-leads/archive-bad-import.js",
    "leads:funnel:quality": "node scripts/latchly-leads/quality-gate.js",
    "leads:funnel:test": "node --test scripts/latchly-leads/tests/*.test.js",
    "resend:login": "resend login",
    "resend:doctor": "resend doctor",
    "leadclaw": "node scripts/leadclaw-pipeline.js",
    "leadclaw:dry": "SKIP_EMAIL=1 node scripts/leadclaw-pipeline.js",
    "leadclaw:local": "SKIP_SCRAPE=1 node scripts/leadclaw-pipeline.js",
    "leadclaw:source": "node scripts/leadclaw-source.js",
    "openclaw": "node scripts/openclaw-pipeline.js",
    "openclaw:dry": "DRY_RUN=true node scripts/openclaw-pipeline.js",
    "openclaw:local": "SKIP_SCOUT=1 node scripts/openclaw-pipeline.js",
    "openclaw:scout": "node scripts/openclaw-scout.js",
    "openclaw:audit": "node scripts/openclaw-audit.js",
    "openclaw:demo": "node scripts/variation-engine/generate.js",
    "openclaw:demo:preview": "node scripts/variation-engine/generate.js --preview",
    "openclaw:demo:rubric": "node scripts/variation-engine/rubric.js",
    "openclaw:demo:old": "node scripts/openclaw-demo-builder.js",
    "openclaw:outreach": "node scripts/openclaw-outreach.js",
    "openclaw:outreach:dry": "DRY_RUN=true node scripts/openclaw-outreach.js",
    "openclaw:closer": "node scripts/openclaw-closer.js",
    "openclaw:maintenance": "node scripts/openclaw-maintenance.js",
    "openclaw:migrate": "node scripts/openclaw-migrate.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@x402/fetch": "^2.7.0",
    "agentmail": "^0.4.6",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.565.0",
    "next": "^14.2.0",
    "puppeteer-core": "^24.39.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "resend": "^6.9.2",
    "stripe": "^20.4.0",
    "tailwind-merge": "^3.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "autoprefixer": "^10.4.20",
    "csv-parse": "^6.1.0",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "postcss": "^8.4.49",
    "resend-cli": "^2.2.1",
    "tailwindcss": "^3.4.17",
    "typescript": "5.9.3"
  }
}
