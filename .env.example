# AgentMail — lead dispatch system
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_INBOX_ID=your_inbox_id_here   # The inbox ID shown in AgentMail dashboard (e.g. "abc123" or the full email address)

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (Neon PostgreSQL)
DATABASE_URL=your_neon_database_url_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
NOTIFY_EMAIL=matt@latchlyai.com
LEAD_DIGEST_TO=matthewseyoum17@gmail.com
LEAD_DIGEST_FROM=Latchly Lead Digest <notifications@latchlyai.com>

# Resend engagement webhooks
# 1. In Resend, open Webhooks and add endpoint:
#    https://www.latchlyai.com/api/webhooks/resend
# 2. Select email.sent, email.delivered, email.opened, email.clicked,
#    email.bounced, email.complained, email.delivery_delayed,
#    email.failed, email.scheduled, and email.suppressed.
# 3. Copy the signing secret here and into Vercel env, then redeploy.
# 4. Enable open tracking on the Resend sending domain.
# 5. Keep click tracking disabled unless a Latchly-domain redirect is added.
RESEND_WEBHOOK_SECRET=whsec_your_resend_webhook_secret_here
LATCHLY_OUTREACH_HTML=1
# Development only: allows unsigned webhook testing when RESEND_WEBHOOK_SECRET is empty.
LATCHLY_WEBHOOK_INSECURE=0

# Latchly daily home service lead digest
LATCHLY_DAILY_TARGET=50
LATCHLY_DAILY_MINIMUM=40
LATCHLY_QUALIFIED_SCORE=8
LATCHLY_LOCAL_SHARE_MIN=0.20
LATCHLY_LOCAL_SHARE_MAX=0.30
# Set to 1 in scheduled CI so duplicate UTC cron entries only run at 8am ET
LATCHLY_REQUIRE_8AM_ET=1
# Optional paid fallback keys for later. Leave empty for free-first operation.
SERPAPI_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Manual CRM "Run scrape now" button. Token needs GitHub workflow scope.
GITHUB_REPO=owner/repo
GITHUB_DISPATCH_TOKEN=github_pat_with_workflow_scope
GITHUB_DISPATCH_REF=main

# Stripe
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link

# OpenClaw config
SITE_BASE=https://latchlyai.com
OUTREACH_FROM=outreach@latchlyai.com
SCOUT_MAX_PER_NICHE=20
SCOUT_MAX_TOTAL=200
AUDIT_MIN_SCORE=8
MAX_EMAILS=20
MAX_MESSAGES=200

# CAN-SPAM physical address
PHYSICAL_ADDRESS=Latchly AI · 123 Main St · Austin, TX 78701

# Booking link
BOOKING_LINK=https://calendly.com/latchlyai/demo

# Demo expiration (days)
DEMO_MAX_AGE_DAYS=30

# Optional: override niches (comma-separated) and cities (semicolon-separated, city,state)
# SCOUT_NICHES=HVAC contractor,plumber,roofing contractor
# SCOUT_CITIES=Dallas,TX;Houston,TX;Phoenix,AZ

# Yelp Fusion API (free tier, 500 req/day — fallback when BBB has no results)
# Get key at https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Vercel Cron secret (used to authenticate cron endpoints)
CRON_SECRET=your_cron_secret_here

# Optional overrides
BATCH_SIZE=150
