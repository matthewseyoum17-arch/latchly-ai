# AgentMail — lead dispatch system
AGENTMAIL_API_KEY=your_agentmail_api_key_here
AGENTMAIL_INBOX_ID=your_inbox_id_here   # The inbox ID shown in AgentMail dashboard (e.g. "abc123" or the full email address)

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database (Neon PostgreSQL)
DATABASE_URL=your_neon_database_url_here

# Email (Resend)
RESEND_API_KEY=your_resend_api_key_here
NOTIFY_EMAIL=matt@latchlyai.com

# Stripe
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your-link

# OpenClaw config
SITE_BASE=https://latchlyai.com
OUTREACH_FROM=outreach@latchlyai.com
SCOUT_MAX_PER_NICHE=20
SCOUT_MAX_TOTAL=200
AUDIT_MIN_SCORE=8
MAX_EMAILS=20
MAX_MESSAGES=200

# CAN-SPAM physical address
PHYSICAL_ADDRESS=Latchly AI · 123 Main St · Austin, TX 78701

# Booking link
BOOKING_LINK=https://calendly.com/latchlyai/demo

# Demo expiration (days)
DEMO_MAX_AGE_DAYS=30

# Optional: override niches (comma-separated) and cities (semicolon-separated, city,state)
# SCOUT_NICHES=HVAC contractor,plumber,roofing contractor
# SCOUT_CITIES=Dallas,TX;Houston,TX;Phoenix,AZ

# SCO (Sales Commission Officer) config — up to 5 SCOs
# Only SCOs with both NAME and EMAIL are loaded.
SCO_1_NAME=Agent1
SCO_1_EMAIL=agent1@example.com
SCO_1_LIMIT=100
SCO_1_TZ=America/New_York
SCO_2_NAME=Agent2
SCO_2_EMAIL=agent2@example.com
SCO_2_LIMIT=100
SCO_2_TZ=America/New_York
SCO_3_NAME=Agent3
SCO_3_EMAIL=agent3@example.com
SCO_3_LIMIT=100
SCO_3_TZ=America/New_York

# Yelp Fusion API (free tier, 500 req/day — fallback when BBB has no results)
# Get key at https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=

# Vercel Cron secret (used to authenticate cron endpoints)
CRON_SECRET=your_cron_secret_here

# Optional overrides
BATCH_SIZE=150
